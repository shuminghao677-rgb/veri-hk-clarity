# Server-only Gemini API key. Do not prefix this with VITE_.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model
AI_MODEL=gemini-3.5-flash
AI_FALLBACK_MODEL=gemini-pro-latest

# Live retrieval cache
HKO_CACHE_MS=180000
RSS_CACHE_MS=180000
TRAFFIC_CACHE_MS=60000
TRAFFIC_CURRENT_MAX_AGE_MINUTES=30
TRAFFIC_NOTICE_RECENT_DAYS=14

# Only search recent RSS items
OFFICIAL_SOURCE_RECENT_DAYS=14

# Official RSS feeds (comma-separated)
OFFICIAL_RSS_FEEDS=https://www.info.gov.hk/gia/rss/general_en.xml,https://www.td.gov.hk/filemanager/rss/en/traffic_notices.xml
